# Server Port
PORT=4000

# Database Connection (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexus?schema=public

# JWT Security Secrets (Expirations in seconds: e.g., 3600 = 1 hour, 604800 = 7 days)
JWT_SECRET=your-jwt-access-token-secret-key
JWT_REFRESH_SECRET=your-jwt-refresh-token-secret-key
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# Google OAuth Config
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# GitHub OAuth Config
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:4000/api/auth/github/callback

# URLs & CORS Allowlist
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
